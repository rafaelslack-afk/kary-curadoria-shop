# ============================================================
# KVO — Kary Vendas Online
# Variáveis de Ambiente — Produção
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o arquivo com valores reais.
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago
NEXT_PUBLIC_MERCADOPAGO_ENV=production
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY_SANDBOX=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY_PRODUCTION=
MERCADOPAGO_ACCESS_TOKEN_SANDBOX=
MERCADOPAGO_ACCESS_TOKEN_PRODUCTION=
MERCADOPAGO_ENV=production
MERCADOPAGO_WEBHOOK_SECRET=

# Melhor Envio
MELHORENVIO_TOKEN_SANDBOX=
MELHORENVIO_TOKEN_PRODUCTION=
MELHORENVIO_ENV=production
MELHORENVIO_CEP_ORIGEM=01500000

# Resend
RESEND_API_KEY=
EMAIL_FROM=contato@karycuradoria.com.br
EMAIL_REPLY_TO=contato@karycuradoria.com.br
EMAIL_ADMIN=contato@karycuradoria.com.br

# Site
NEXT_PUBLIC_SITE_URL=https://karycuradoria.com.br
NEXT_PUBLIC_SITE_NAME=Kary Curadoria

# Lancamento da loja
STORE_PRELAUNCH_ENABLED=true
NEXT_PUBLIC_STORE_LAUNCH_AT=
